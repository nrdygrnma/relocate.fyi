{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": [
    ".nuxt/nuxt.d.ts",
    "app/**/*",
    "server/**/*",
    "test/**/*",
    "playwright.config.ts",
    "nuxt.config.ts",
    "prisma.config.ts"
  ]
}
